# LinkedIn Authentication Cookies
# Get these from your browser's developer tools (Application > Cookies)
#
# LI_AT: The main authentication cookie (value of 'li_at' cookie)
# CSRF_TOKEN: The CSRF token (value of 'JSESSIONID' cookie WITHOUT surrounding quotes)

LI_AT=
CSRF_TOKEN=ajax:0000000000000000000

# Optional: proxy URL for all requests (supports http/https/socks5)
# PROXY=http://user:pass@host:port
